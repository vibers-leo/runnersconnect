<div class="min-h-[calc(100-73px)] flex flex-col items-center justify-center p-6 sm:p-12">
  <div class="max-w-md w-full">
    <div class="text-center mb-10">
      <h2 class="text-4xl font-black text-gray-900 tracking-tighter mb-2">새 비밀번호 설정 🔐</h2>
      <p class="text-gray-500 font-medium">새로운 비밀번호를 입력해주세요.</p>
    </div>

    <div class="bg-white rounded-[2.5rem] shadow-xl shadow-blue-50 border border-gray-100 p-8 sm:p-10">
      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "space-y-6" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>
        <%= f.hidden_field :reset_password_token %>

        <div>
          <%= f.label :password, "새 비밀번호", class: "block text-sm font-bold text-gray-700 mb-2" %>
          <% if @minimum_password_length %>
            <p class="text-xs text-gray-400 mb-2">(<%= @minimum_password_length %>자 이상)</p>
          <% end %>
          <%= f.password_field :password, autofocus: true, autocomplete: "new-password", placeholder: "새 비밀번호 입력", class: "block w-full px-5 py-4 rounded-2xl border-gray-200 focus:ring-blue-500 focus:border-blue-500 shadow-sm transition-all" %>
        </div>

        <div>
          <%= f.label :password_confirmation, "새 비밀번호 확인", class: "block text-sm font-bold text-gray-700 mb-2" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "한 번 더 입력", class: "block w-full px-5 py-4 rounded-2xl border-gray-200 focus:ring-blue-500 focus:border-blue-500 shadow-sm transition-all" %>
        </div>

        <div class="pt-4">
          <%= f.submit "비밀번호 변경하기", class: "w-full py-5 bg-blue-600 hover:bg-blue-700 text-white font-black rounded-2xl shadow-xl shadow-blue-100 transition-all active:scale-[0.98] text-lg" %>
        </div>
      <% end %>

      <div class="mt-8 text-center pt-8 border-t border-gray-50">
        <p class="text-sm text-gray-400 font-bold mb-4">비밀번호가 기억나셨나요?</p>
        <%= link_to "로그인하러 가기", new_session_path(resource_name), class: "inline-block py-3 px-8 bg-gray-50 hover:bg-gray-100 text-gray-900 font-black rounded-xl transition-all" %>
      </div>
    </div>
  </div>
</div>

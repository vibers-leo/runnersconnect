<div class="min-h-[calc(100vh-73px)] flex flex-col items-center justify-center p-6 sm:p-12">
  <div class="max-w-md w-full">
    <div class="text-center mb-10">
      <span class="eyebrow mb-4">Runner's Connect</span>
      <h2 class="text-4xl font-black text-gray-900 tracking-tighter mb-2 mt-4">반가워요!</h2>
      <p class="text-gray-500 font-medium">러너스 커넥트에 오신 것을 환영합니다.</p>
    </div>

    <div class="card-premium">
      <div class="card-premium-inner sm:!p-10">
        <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-6" }) do |f| %>
          <div>
            <%= f.label :email, "이메일 주소", class: "block text-sm font-bold text-gray-700 mb-2" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "runners@example.com", class: "block w-full px-5 py-4 rounded-2xl border-gray-200 focus:ring-indigo-500 focus:border-indigo-500 shadow-sm transition-all" %>
          </div>

          <div>
            <div class="flex justify-between items-center mb-2">
              <%= f.label :password, "비밀번호", class: "block text-sm font-bold text-gray-700" %>
              <%- if devise_mapping.recoverable? && controller_name != 'passwords' && action_name != 'edit' %>
                <%= link_to "비밀번호 찾기", new_password_path(resource_name), class: "text-xs font-bold text-indigo-600 hover:text-indigo-700" %>
              <% end %>
            </div>
            <%= f.password_field :password, autocomplete: "current-password", placeholder: "••••••••", class: "block w-full px-5 py-4 rounded-2xl border-gray-200 focus:ring-indigo-500 focus:border-indigo-500 shadow-sm transition-all" %>
          </div>

          <% if devise_mapping.rememberable? %>
            <div class="flex items-center">
              <%= f.check_box :remember_me, class: "h-5 w-5 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded-lg mr-2" %>
              <%= f.label :remember_me, "로그인 유지", class: "text-sm font-bold text-gray-500" %>
            </div>
          <% end %>

          <div class="pt-4">
            <%= f.submit "로그인", class: "w-full btn-supanova justify-center bg-indigo-600 hover:bg-indigo-700 text-white text-lg shadow-lg" %>
          </div>
        <% end %>

        <div class="mt-6">
          <div class="relative">
            <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-gray-200"></div></div>
            <div class="relative flex justify-center text-sm"><span class="px-2 bg-white text-gray-500">또는</span></div>
          </div>
          <div class="mt-4 space-y-3">
            <%= button_to user_kakao_omniauth_authorize_path, method: :post, class: "w-full flex items-center justify-center gap-3 px-4 py-3 rounded-full font-medium text-gray-900 hover:opacity-90 transition", style: "background-color: #FEE500;", data: { turbo: false } do %>
              <svg width="20" height="20" viewBox="0 0 20 20"><path d="M10 3C5.58 3 2 5.8 2 9.2c0 2.17 1.44 4.08 3.6 5.16l-.92 3.44c-.08.29.25.53.5.36l4.12-2.72c.23.02.46.04.7.04 4.42 0 8-2.8 8-6.28S14.42 3 10 3z" fill="#3C1E1E"/></svg>
              카카오로 로그인
            <% end %>
            <%= button_to user_google_oauth2_omniauth_authorize_path, method: :post, class: "w-full flex items-center justify-center gap-3 px-4 py-3 rounded-full font-medium text-gray-700 border border-gray-200 hover:bg-gray-50 transition", data: { turbo: false } do %>
              <svg width="20" height="20" viewBox="0 0 48 48"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/></svg>
              Google로 로그인
            <% end %>
            <%= button_to user_naver_omniauth_authorize_path, method: :post, class: "w-full flex items-center justify-center gap-3 px-4 py-3 rounded-full font-medium text-white hover:opacity-90 transition", style: "background-color: #03C75A;", data: { turbo: false } do %>
              <svg width="20" height="20" viewBox="0 0 20 20"><path d="M13.5 10.7L6.2 2H2v16h4.5V9.3L13.8 18H18V2h-4.5v8.7z" fill="white"/></svg>
              네이버로 로그인
            <% end %>
          </div>
        </div>

        <div class="mt-8 text-center pt-8 border-t border-gray-100">
          <p class="text-sm text-gray-400 font-bold mb-4">아직 계정이 없으신가요?</p>
          <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
            <%= link_to "30초 만에 회원가입", new_user_registration_path, class: "btn-supanova bg-gray-50 hover:bg-gray-100 text-gray-900 text-sm" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="max-w-6xl mx-auto px-6 py-16">
  <%= render 'shared/page_header',
      title: "대회 캘린더",
      icon: "📅",
      description: "전국 러닝 대회 일정을 한눈에 확인하세요. 플랫폼 대회와 외부 대회를 모두 포함합니다." %>

  <%# 월간 네비게이션 %>
  <div class="flex items-center justify-between mb-8 bg-white rounded-2xl border border-gray-200 shadow-sm p-4">
    <div class="flex items-center gap-4">
      <%= link_to race_calendar_path(year: @prev_date.year, month: @prev_date.month), class: "p-2 hover:bg-gray-100 rounded-lg transition-colors" do %>
        <svg class="w-5 h-5 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
      <% end %>
      <h2 class="text-2xl font-black text-gray-900">
        <%= @year %>년 <%= @month %>월
      </h2>
      <%= link_to race_calendar_path(year: @next_date.year, month: @next_date.month), class: "p-2 hover:bg-gray-100 rounded-lg transition-colors" do %>
        <svg class="w-5 h-5 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
      <% end %>
    </div>
    <div>
      <%= link_to "이번 달", race_calendar_path, class: "px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold rounded-lg text-sm transition-colors" %>
    </div>
  </div>

  <%# 검색 %>
  <div class="mb-8">
    <%= form_tag race_calendar_path, method: :get, class: "flex gap-4" do %>
      <input type="hidden" name="year" value="<%= @year %>">
      <input type="hidden" name="month" value="<%= @month %>">
      <input type="text" name="q" value="<%= params[:q] %>"
             placeholder="대회명으로 검색..."
             class="flex-1 px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-transparent text-sm">
      <button type="submit" class="px-6 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-bold rounded-xl transition-colors text-sm">
        검색
      </button>
    <% end %>
  </div>

  <%# 대회 목록 %>
  <% if @combined_races.any? %>
    <div class="space-y-4">
      <% current_date = nil %>
      <% @combined_races.each do |item| %>
        <%# 날짜 구분 %>
        <% if current_date != item[:date] %>
          <% current_date = item[:date] %>
          <div class="flex items-center gap-4 pt-4">
            <div class="flex-shrink-0 w-16 h-16 bg-indigo-600 rounded-2xl flex flex-col items-center justify-center text-white shadow-lg">
              <span class="text-xs font-bold"><%= current_date.strftime('%m') %>월</span>
              <span class="text-xl font-black leading-none"><%= current_date.day %></span>
              <span class="text-[10px]"><%= %w[일 월 화 수 목 금 토][current_date.wday] %></span>
            </div>
            <div class="flex-1 h-px bg-gray-200"></div>
          </div>
        <% end %>

        <%# 대회 카드 %>
        <div class="ml-20 bg-white rounded-2xl border border-gray-200 shadow-sm p-6 hover:shadow-md transition-all">
          <div class="flex items-start justify-between">
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-2">
                <% if item[:type] == "platform" %>
                  <span class="px-2 py-0.5 bg-indigo-100 text-indigo-700 text-xs font-black rounded-lg">플랫폼</span>
                <% else %>
                  <span class="px-2 py-0.5 bg-orange-100 text-orange-700 text-xs font-black rounded-lg">외부</span>
                <% end %>
                <h3 class="text-lg font-bold text-gray-900"><%= item[:title] %></h3>
              </div>

              <div class="flex flex-wrap items-center gap-4 text-sm text-gray-500">
                <% if item[:location].present? %>
                  <span class="flex items-center gap-1">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                    <%= item[:location] %>
                  </span>
                <% end %>

                <% if item[:type] == "external" %>
                  <% race = item[:race] %>
                  <% if race.distances.any? %>
                    <span class="text-xs"><%= race.distances.join(" / ") %></span>
                  <% end %>
                  <% if race.fee_info.present? %>
                    <span class="text-xs text-gray-400"><%= race.fee_info %></span>
                  <% end %>
                <% end %>
              </div>
            </div>

            <div class="flex-shrink-0 ml-4">
              <% if item[:type] == "platform" %>
                <%= link_to item[:path], class: "inline-flex items-center px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white font-bold rounded-xl text-sm transition-colors" do %>
                  참가 신청
                <% end %>
              <% else %>
                <% ext_race = item[:race] %>
                <% if ext_race.registration_url.present? %>
                  <a href="<%= ext_race.registration_url %>" target="_blank" rel="noopener noreferrer"
                     class="inline-flex items-center px-4 py-2 bg-orange-500 hover:bg-orange-600 text-white font-bold rounded-xl text-sm transition-colors">
                    외부 신청
                    <svg class="w-3 h-3 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                  </a>
                <% else %>
                  <a href="<%= ext_race.source_url %>" target="_blank" rel="noopener noreferrer"
                     class="inline-flex items-center px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold rounded-xl text-sm transition-colors">
                    자세히 보기
                  </a>
                <% end %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="py-24 text-center bg-gray-50 rounded-2xl border border-dashed border-gray-200">
      <div class="w-16 h-16 bg-white rounded-2xl flex items-center justify-center mx-auto mb-6 text-gray-200 border border-gray-100">
        <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
      </div>
      <h3 class="text-xl font-bold text-gray-900 mb-2"><%= @year %>년 <%= @month %>월에 예정된 대회가 없습니다</h3>
      <p class="text-gray-500 text-sm">다른 달을 확인해보세요.</p>
    </div>
  <% end %>
</div>
